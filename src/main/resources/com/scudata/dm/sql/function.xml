	<FUNCTION name="isdigit" paramcount="1" value="">
      <INFO dbtype="ESPROC" value="isdigit(?1)"/>
	  <INFO dbtype="MYSQL" value="?1 REGEXP '^[0-9]+$'"/>
	  <INFO dbtype="HSQL" value="regexp_matches(?1,'^[0-9]+$')"/>
	  <INFO dbtype="ORACLE" value="CASE  WHEN REGEXP_LIKE(?1, '^[0-9]+$') THEN 'TRUE' ELSE 'FALSE'  END"/>
	  <INFO dbtype="DUCKDB" value="regexp_matches(?1,'^[0-9]+$')"/>
	  <INFO dbtype="BIGQUERY" value="REGEXP_CONTAINS(?1, r'^[0-9]')"/>
	  <INFO dbtype="POSTGRES" value="?1 ~ &#39;^[+-]{0,1}[0-9]+(\.[0-9]+){0,1}$&#39;"/>
	</FUNCTION>
	<FUNCTION name="isalpha" paramcount="1" value="">
