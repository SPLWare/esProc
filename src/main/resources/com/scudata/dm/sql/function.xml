	  <INFO dbtype="ORACLE" value="CASE  WHEN REGEXP_LIKE(?1, '^[A-Za-z]+$') THEN 'TRUE' ELSE 'FALSE'  END"/>
	  <INFO dbtype="DUCKDB" value="regexp_matches(?1,'^[A-Za-z]+$')"/>
	  <INFO dbtype="BIGQUERY" value="REGEXP_CONTAINS(?1, r'^[A-Za-z]+$')"/>
	  <INFO dbtype="POSTGRES" value="?1 ~ '^[[:alpha:]]+$'"/>
	</FUNCTION>
	<FUNCTION name="getsubs" paramcount="2" value="">
      <INFO dbtype="ESPROC" value="substr(?1,?2)"/>
	  <INFO dbtype="ORACLE" value="CASE  WHEN INSTR(?1,?2) > 0 THEN  SUBSTR(?1,INSTR(?1,?2) + LENGTH(?2))  ELSE  NULL  END"/>
	  <INFO dbtype="MYSQL" value="IF(LOCATE(?2, ?1) > 0, SUBSTRING(?1, LOCATE(?2, ?1) + LENGTH(?2)), NULL)"/>
	  <INFO dbtype="DUCKDB" value="substr(?1, position(?2 IN ?1) + length(?2))"/>
	  <INFO dbtype="BIGQUERY" value="CASE WHEN STRPOS(?1,?2) &gt; 0 THEN SUBSTR(?1,STRPOS(?1,?2)+LENGTH(?2)) ELSE NULL END"/>
	  <INFO dbtype="POSTGRES" value="CASE WHEN STRPOS(?1,?2) &gt; 0 THEN SUBSTR(?1,STRPOS(?1,?2)+LENGTH(?2)) ELSE NULL END"/>
	</FUNCTION>
	<FUNCTION name="getsubs" paramcount="3" value="">
      <INFO dbtype="ESPROC" value="substr(?1,?2,?3)"/>
	  <INFO dbtype="ORACLE" value="CASE  WHEN INSTR(?1,?2,1,?3) > 0 THEN   SUBSTR(?1,INSTR(?1,?2,1,?3) + LENGTH(?2))  ELSE    NULL END"/>
	  <INFO dbtype="MYSQL" value="IF(SUBSTRING_INDEX(?1, ?2, ?3) > 0,SUBSTRING(?1,LENGTH(SUBSTRING_INDEX(?1, ?2, ?3)) + LENGTH(?2) + 1),NULL)"/>
	  <INFO dbtype="BIGQUERY" value="CASE WHEN INSTR(?1,?2,INSTR(?1,?2)+?3-1) &gt; 0 THEN SUBSTR(?1,INSTR(?1,?2,INSTR(?1,?2)+?3-1)+LENGTH(?2)) ELSE NULL END"/>
	  <INFO dbtype="POSTGRES" value="CASE WHEN regexp_instr(?1,?2,1,?3) &gt; 0 THEN substring(?1,regexp_instr(?1,?2,1,?3) + length(?2)) ELSE NULL END"/>
    </FUNCTION>
	<FUNCTION name="ipos" paramcount="2" value="">
      <INFO dbtype="ESPROC" value="pos@c(?1,?2)"/>
	  <INFO dbtype="ORACLE" value="INSTR(UPPER(?1),UPPER(?2))"/>
	  <INFO dbtype="MYSQL" value="INSTR(?1,?2)"/>
	  <INFO dbtype="HSQL" value="CASE WHEN LOCATE(UPPER(?2),UPPER(?1)) > 0  THEN LOCATE(UPPER(?2),UPPER(?1)) ELSE NULL END"/>
	  <INFO dbtype="DUCKDB" value="strpos(lower(?1),lower(?2));"/>
	  <INFO dbtype="BIGQUERY" value="REGEXP_INSTR(?1,r?2)"/>
	  <INFO dbtype="POSTGRES" value="POSITION(?2 IN ?1)"/>
	</FUNCTION>
	<FUNCTION name="ipos" paramcount="3" value="">
      <INFO dbtype="ESPROC" value="pos@c(?1,?2,?3)"/>
	  <INFO dbtype="ORACLE" value="INSTR(UPPER(?1),UPPER(?2),1,?3)"/>
	  <INFO dbtype="MYSQL" value="IF(INSTR(SUBSTRING(?1,?3),?2) > 0, INSTR(SUBSTRING(?1,?3),?2)+?3-1,null)"/>
	  <INFO dbtype="HSQL" value="CASE  WHEN LOCATE(UPPER(?2),UPPER(?1),?3) > 0 THEN LOCATE(UPPER(?2),UPPER(?1), ?3) ELSE NULL END"/>
	  <INFO dbtype="DUCKDB" value="CASE  WHEN position(lower(?2) IN lower(substr(?1,?3))) &gt; 0  THEN position(lower(?2) IN lower(substr(?1,?3))) + (?3-1)  ELSE 0 END"/>
	  <INFO dbtype="BIGQUERY" value="REGEXP_INSTR(?1,r?2,?3)"/>
	  <INFO dbtype="POSTGRES" value="CASE WHEN strpos(substring(?1,?3),?2) &gt; 0 THEN ?3 - 1 + strpos(substring(?1,?3),?2) ELSE 0 END"/>
	</FUNCTION>
	<FUNCTION name="igetsubs" paramcount="2" value="">
       <INFO dbtype="ESPROC" value="substr@c(?1,?2)"/>
	   <INFO dbtype="ORACLE" value="CASE  WHEN INSTR(UPPER(?1),UPPER(?2)) > 0 THEN   SUBSTR(?1,INSTR(UPPER(?1),UPPER(?2)) + LENGTH(?2))  ELSE  NULL END"/>
	   <INFO dbtype="MYSQL" value="CASE WHEN LOCATE(?2,?1) > 0 THEN SUBSTRING(?1, LOCATE(?2, ?1) + CHAR_LENGTH(?2)) ELSE NULL END"/>
	   <INFO dbtype="HSQL" value="CASE   WHEN LOCATE(UPPER(?2),UPPER(?1)) > 0 THEN SUBSTR(?1,LOCATE(UPPER(?2),UPPER(?1)) + LENGTH(?2) )  ELSE NULL END"/>
	   <INFO dbtype="DUCKDB" value="CASE  WHEN position(lower(?2) IN lower(?1)) &gt; 0  THEN substr(?1,position(lower(?2) IN lower(?1)) + length(?2))  ELSE NULL END "/>
	   <INFO dbtype="BIGQUERY" value="IF(INSTR(LOWER(?1),LOWER(?2)) &gt; 0,SUBSTR(?1, INSTR(LOWER(NAME),LOWER(?2))+LENGTH(?2)),NULL)"/>
	  <INFO dbtype="POSTGRES" value="CASE WHEN POSITION(LOWER(?2) IN LOWER(?1)) &gt; 0 THEN SUBSTRING(?1 FROM POSITION(LOWER(?2) IN LOWER(?1)) + LENGTH(?2)) ELSE NULL END"/>
	</FUNCTION>
	<FUNCTION name="igetsubs" paramcount="3" value="">
       <INFO dbtype="ESPROC" value="substr@c(?1,?2,?3)"/>
	   <INFO dbtype="ORACLE" value="CASE  WHEN INSTR(UPPER(?1),UPPER(?2),1,NVL(?3,1)) > 0 THEN  SUBSTR(?1,INSTR(UPPER(?1),UPPER(?2),1,NVL(?3,1)) + LENGTH(?2))  ELSE  NULL END"/>
	   <INFO dbtype="MYSQL" value="CASE WHEN REGEXP_INSTR(?1,?2,1,?3,0,'i') > 0 THEN SUBSTRING(?1,REGEXP_INSTR(?1,?2,1,?3,1,'i')) ELSE NULL END"/>
	   <INFO dbtype="HSQL" value="CASE  WHEN LOCATE(UPPER(?2),UPPER(?1),?3) > 0  THEN SUBSTR(?1,LOCATE(UPPER(?2),UPPER(?1),?3) + LENGTH(?2))  ELSE NULL END"/>
	   <INFO dbtype="BIGQUERY" value="CASE WHEN REGEXP_INSTR(LOWER(?1),LOWER(?2),1,?3) &gt; 0 THEN SUBSTR(?1,REGEXP_INSTR(LOWER(?1),LOWER(?2),1,?3)+ LENGTH(?2)) ELSE NULL END"/>
	  <INFO dbtype="POSTGRES" value="CASE WHEN regexp_instr(lower(?1), lower(?2),1,?3) &gt; 0 THEN substring(?1 FROM regexp_instr(lower(?1), lower(?2),1,?3) + length(?2)) ELSE NULL END"/>
	</FUNCTION>

